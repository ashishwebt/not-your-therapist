{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI",
      "type": "debugpy",
      "request": "launch",
      "python": "${command:python.interpreterPath}",
      "module": "uvicorn",
      "args": [
        
        "main:app",
        "--port",
        "8000",
        "--reload"
      ],
      "console": "internalConsole",
      "justMyCode": false,
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "React",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/not-your-therapist"
    }
  ],
  "compounds": [
    {
      "name": "fullstack",
      "configurations": ["React", "FastAPI"],
      "stopAll": true
    }
  ]
}
